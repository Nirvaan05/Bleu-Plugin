{
  "//": "EXAMPLE ONLY - not loaded automatically. Bleu's hooks are intentionally NOT active in this repo: cloning a public repo should never run scripts against your files. To exercise the harness locally, copy this to .claude/settings.json (which stays gitignored). See plugins/bleu/skills/bleu/references/claude-code-integration.md.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-session-start.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-file-changed.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "kb-linter",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-subagent-stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-autocommit.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-autocommit.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
